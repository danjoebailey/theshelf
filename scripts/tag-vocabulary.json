  "design_decisions_locked": {
    "tagging_approach": "Option B — through Claude Code / Opus 4.6 in marathon sessions, using the Max subscription. Rejected scripted API pass because Opus via Claude Code is higher-quality than Haiku script and free vs expensive.",
    "scoring_formula": "final = 0.45 * global_vibe_match + 0.45 * genre_vibe_match + 0.1 * tag_match. Reweighted from original 0.4/0.4/0.2 after user explicitly valued vibes over tags during pilot. Tags are now primarily a filter/query tool, not a recommendation ranker. Four global vibes now: prose_craft, prose_style, warmth, intensity.",
    "user_profile_scope": "Per genre bucket (5 buckets), not per raw genre (15). Global vibes averaged across all rated books.",
    "cold_start": "Require ≥5 rated books per bucket before personalized scoring in that bucket; below that, fall back to popular/top-rated.",
    "obi_integration": "Reuse existing /api/ask-obi endpoint as per-card 'why this fits you' layer. Do not build a new endpoint.",
    "rec_library_first": "Tag rec library (3,226 books) before primary catalog (~11,500). Higher leverage per book since rec library feeds Paige's hidden_gems and new_to_me modes.",
    "vibes_total": "11 vibes: 4 global + 7 genre-conditional"
  }
}