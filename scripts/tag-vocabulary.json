{
  "version": "draft-5-intensity-added",
  "note": "Tag vocabulary + revised prose vibe axes. Replaced prose_density + ornamentation with prose_craft (utilitarian → crafted, measures sentence-level voice quality) + prose_style (sparse → baroque, measures direction). This fixes a load-bearing flaw surfaced during pilot tagging: Stoner and Lee Child both scored ~3 on density, which is clearly wrong from a taste standpoint. Craft and style are now independent axes.",
  "schema": {
    "tags_per_book": "10-15",
    "vibes_per_book": 10,
    "vibe_scale": "integer 0-10",
    "tag_selection_rule": "For each book, Claude sees only (universal tags) + (genre-specific tags for the book's genre bucket). No global 400-tag dump."
  },
  "genre_buckets": {
    "literary": {
      "raw_genres": [
        "Fiction",
        "Historical Fiction",
        "Biography"
      ],
      "description": "Literary fiction of any era, biographical/memoir-flavored fiction, historical fiction that leans literary."
    },
    "speculative": {
      "raw_genres": [
        "Fantasy",
        "Sci-Fi",
        "Horror",
        "Graphic Novel"
      ],
      "description": "Anything with speculative elements — secondary worlds, future tech, supernatural horror, genre-literary crossovers."
    },
    "crime": {
      "raw_genres": [
        "Mystery",
        "Thriller"
      ],
      "description": "Crime, detective, mystery, psychological thriller, espionage, noir."
    },
    "commercial_warm": {
      "raw_genres": [
        "Romance",
        "Young Adult"
      ],
      "description": "Romance (all heat levels), YA contemporary, coming-of-age that targets teen/young adult audiences."
    },
    "nonfiction": {
      "raw_genres": [
        "Non-Fiction",
        "History",
        "Self-Help"
      ],
      "description": "Literary nonfiction, essay, memoir, narrative history. Note: travel/nature/theory nonfiction explicitly excluded from catalog additions per project feedback rules."
    }
  },
  "vibe_dimensions": {
    "global": {
      "note": "These three vibes are averaged across ALL rated books in the user shelf. They capture intrinsic prose-taste preferences that travel with the reader regardless of genre.",
      "prose_craft": {
        "scale": "0 = utilitarian, 10 = highly crafted",
        "definition": "Does the sentence-level voice reward slow reading? Is the prose deliberate and distinctive, regardless of whether it is sparse or dense? A sparse writer can be highly crafted (Carver, Williams, McCarthy-The-Road) and a dense writer can be utilitarian (generic doorstopper fantasy). This axis is INDEPENDENT of style — a Stoner-loving reader and a Pynchon-loving reader may both sit at 9-10 here even though their prose_style scores differ completely.",
        "0_example": "Dan Brown, James Patterson — prose as pure plot-delivery mechanism",
        "3_example": "Lee Child, airport thrillers — competent but utilitarian",
        "6_example": "Stephen King, most mainstream literary — solid craft without distinctive sentence-level voice",
        "9_example": "John Williams Stoner, Kazuo Ishiguro, Raymond Carver, Marilynne Robinson — highly crafted, sentence-level voice that pulls you in",
        "10_example": "Cormac McCarthy, Vladimir Nabokov, Toni Morrison, William Faulkner — prose as load-bearing as plot"
      },
      "prose_style": {
        "scale": "0 = sparse/plain, 10 = dense/baroque",
        "definition": "Which direction does the prose go? Short declarative sentences and minimal vocabulary at 0; long nested clauses, elaborate syntax, and baroque vocabulary at 10. This is INDEPENDENT of craft — it answers which kind of prose, not how good.",
        "0_example": "Raymond Carver, Hemingway early, Cormac McCarthy The Road — pared to the bone",
        "3_example": "John Williams Stoner, most plain-style literary — unshowy but slightly fuller than Carver",
        "5_example": "Anne Tyler, Kazuo Ishiguro, Marilynne Robinson — middle register, controlled but lyrical",
        "8_example": "Cormac McCarthy Blood Meridian, Toni Morrison, William Faulkner — lush, elaborate, sentence complexity",
        "10_example": "Thomas Pynchon, Marcel Proust, David Foster Wallace, William H. Gass — maximalist baroque"
      },
      "warmth": {
        "scale": "0 = cold/detached, 10 = warm/human",
        "0_example": "Michel Houellebecq, Bret Easton Ellis, Cormac McCarthy Blood Meridian",
        "5_example": "Saul Bellow, Philip Roth",
        "10_example": "Elizabeth Strout, Kent Haruf, Becky Chambers, Fredrik Backman"
      },
      "intensity": {
        "scale": "0 = gentle/restrained, 10 = relentlessly visceral/graphic/charged",
        "definition": "How viscerally charged is the reading experience? Measures graphic violence, physical intensity, rawness, relentless pressure. INDEPENDENT of warmth — Blood Meridian is cold AND intense, Becky Chambers is warm AND gentle, but Bukowski is warm-ish AND gritty. This is the axis that distinguishes quiet literary (Stoner) from visceral literary (Céline, Bukowski, McCarthy) without relying on tone or warmth.",
        "0_example": "Elizabeth Strout, Kent Haruf, Becky Chambers, Alexander McCall Smith — gentle, non-charged",
        "3_example": "John Williams Stoner, Kazuo Ishiguro, Marilynne Robinson — quiet, restrained even when dealing with heavy content",
        "5_example": "Philip Roth, Richard Russo, most mainstream literary — present but not relentless",
        "7_example": "Charles Bukowski, Céline, Dan Fante, Denis Johnson — gritty, raw, unflinching but not graphically violent",
        "9_example": "Cormac McCarthy Blood Meridian, Bret Easton Ellis American Psycho, Last Exit to Brooklyn — relentlessly visceral",
        "10_example": "Extreme horror, splatterpunk — de Sade tier relentlessness"
      }
    },
    "genre_conditional": {
      "note": "These seven vibes are averaged within each genre bucket separately. The same reader can have very different pace/difficulty/tone preferences in fantasy vs literary fiction.",
      "pace": {
        "scale": "0 = meditative, 10 = propulsive",
        "0_example": "Virginia Woolf, Marilynne Robinson's Gilead, Patrick Modiano",
        "5_example": "Kazuo Ishiguro, Alice Munro",
        "10_example": "Lee Child, Dan Brown, Andy Weir's The Martian"
      },
      "moral_complexity": {
        "scale": "0 = clear/black-and-white, 10 = ambiguous/nihilistic",
        "0_example": "Classic cozy mystery, Brandon Sanderson heroic fantasy",
        "5_example": "Most mainstream literary fiction",
        "10_example": "Cormac McCarthy, Joseph Conrad's Heart of Darkness, Gillian Flynn's Gone Girl"
      },
      "emotional_register": {
        "scale": "0 = bleak, 10 = joyful",
        "0_example": "Cormac McCarthy's The Road, Imre Kertész",
        "5_example": "Most mid-career literary fiction",
        "10_example": "Becky Chambers, Fredrik Backman, Alexander McCall Smith"
      },
      "interiority": {
        "scale": "0 = external/plot-driven, 10 = internal/psychological",
        "0_example": "Lee Child, most thrillers, Brandon Sanderson",
        "5_example": "Most mainstream literary fiction",
        "10_example": "Virginia Woolf, Rachel Cusk's Outline trilogy, Karl Ove Knausgård, Javier Marías"
      },
      "tone": {
        "scale": "0 = serious, 10 = playful",
        "0_example": "Cormac McCarthy, most Holocaust fiction, Kazuo Ishiguro",
        "5_example": "Most literary fiction",
        "10_example": "Terry Pratchett, P.G. Wodehouse, Douglas Adams, Richard Brautigan"
      },
      "difficulty": {
        "scale": "0 = accessible, 10 = demanding",
        "0_example": "Airport thrillers, cozy mysteries, most commercial romance",
        "5_example": "Most mainstream literary fiction",
        "10_example": "Gene Wolfe's Book of the New Sun, James Joyce's Ulysses, Thomas Pynchon's Gravity's Rainbow"
      },
      "fabulism": {
        "scale": "0 = realist, 10 = fabulist/speculative",
        "definition": "Renamed from realism to fabulism so the scale direction matches the name. Higher = more unreal. A strict realist novel is 0; a pure fantasy is 9-10; magical realism sits around 5.",
        "0_example": "Anne Tyler, Richard Russo, Jonathan Franzen — pure realism",
        "5_example": "Toni Morrison Beloved, Gabriel García Márquez — realism with magical intrusions",
        "10_example": "Jorge Luis Borges, Italo Calvino, Jeff VanderMeer — fully fabulist"
      }
    }
  },
